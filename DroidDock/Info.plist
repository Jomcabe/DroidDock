<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
	<key>CFBundleDisplayName</key>
	<string>DroidDock</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>DroidDock</string>
	<key>CFBundlePackageType</key>
	<string>APPL</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>LSMinimumSystemVersion</key>
	<string>$(MACOSX_DEPLOYMENT_TARGET)</string>
	<key>LSApplicationCategoryType</key>
	<string>public.app-category.developer-tools</string>
	<key>NSHighResolutionCapable</key>
	<true/>
	<key>NSPrincipalClass</key>
	<string>NSApplication</string>
	<key>NSSupportsAutomaticGraphicsSwitching</key>
	<true/>
	<!-- Stop LaunchServices from starting a second copy of DroidDock from the
	     same path. Cross-path duplicates (e.g. a Debug build vs the installed
	     Release) are caught at runtime in AppDelegate.enforceSingleInstance(). -->
	<key>LSMultipleInstancesProhibited</key>
	<true/>
	<key>NSHumanReadableCopyright</key>
	<string>DroidDock — MIT-licensed. Bundles scrcpy (Apache-2.0) and Android platform-tools.</string>
	<!-- DroidDock positions the borderless scrcpy mirror via the Accessibility
	     API; macOS gates that behind a user grant in Privacy &amp; Security. -->
	<key>NSAppleEventsUsageDescription</key>
	<string>DroidDock uses macOS automation to keep the mirror window docked to its frame.</string>
	<!-- Sparkle automatic updates. Replace SUPublicEDKey with your own EdDSA
	     public key from `generate_keys` (the private key stays on your machine /
	     in a CI secret and signs each release). The appcast is published as a
	     release asset, so the "latest release" URL always serves the newest one.
	     See the README's "Automatic updates" section. -->
	<key>SUFeedURL</key>
	<string>https://github.com/Jomcabe/DroidDock/releases/latest/download/appcast.xml</string>
	<key>SUPublicEDKey</key>
	<string>REPLACE_WITH_YOUR_SPARKLE_EDDSA_PUBLIC_KEY</string>
	<key>SUEnableAutomaticChecks</key>
	<true/>
	<key>SUScheduledCheckInterval</key>
	<integer>86400</integer>
</dict>
</plist>
